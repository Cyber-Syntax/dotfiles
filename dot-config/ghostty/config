#
#   $HOME/.config/ghostty/config
#
# Run `ghostty +show-config --default --docs` to view a list of
# all available config options and their default values.
#
# https://ghostty.org/docs/config.


font-style = "JetBrainsMono Nerd Font"
font-family = "JetBrainsMono Nerd Font"
font-family-bold = "JetBrainsMono NF Bold"
font-family-italic = "JetBrainsMono NF Italic"
font-family-bold-italic = "JetBrainsMono NF Bold Italic"
font-size = 18
theme = Monokai Pro
window-theme = ghostty
confirm-close-surface = false

# remove title-bar
window-decoration = none

# Keybinding
keybind = unconsumed:ctrl+shift+t=new_tab
keybind = alt+enter=new_tab
keybind = alt+q=close_tab
keybind = alt+a=previous_tab
keybind = alt+d=next_tab
# keybind = ctrl+z=close_surface
# keybind = ctrl+d=new_split:right
